<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="?android:attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <!-- No 순번 -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.8"
        android:layout_gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">
        <TextView
            android:id="@+id/tvNo"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_light_gray_rounded"
            android:gravity="center"
            android:text="1"
            android:textColor="#555555"
            android:textSize="12sp" />
    </FrameLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#EAEAEA" />

    <!-- TEL (고객명, 전화번호 및 초 1줄 통합) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="3.0"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/tvCustomerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="부모님"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center_horizontal" />

        <TextView
            android:id="@+id/tvPhoneNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0555828585 :37"
            android:textSize="11sp"
            android:textColor="#757575"
            android:layout_marginTop="1dp"
            android:gravity="center_horizontal" />
    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#EAEAEA" />

    <!-- 일자 (바탕색 없음) -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2.4"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">
        <TextView
            android:id="@+id/tvCallDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="2026.05.22"
            android:textColor="#212121"
            android:textSize="12sp" />
    </FrameLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#EAEAEA" />

    <!-- 시간 (바탕색 없음) -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.8"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">
        <TextView
            android:id="@+id/tvCallTimeShort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="20:12"
            android:textColor="#212121"
            android:textSize="12sp" />
    </FrameLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#EAEAEA" />

    <!-- 전송 상태 -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:text="성공"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center" />

    <!-- 구분선 -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#EAEAEA" />

    <!-- 듣기 재생 아이콘 -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.0"
        android:layout_gravity="center_vertical">
        <ImageView
            android:id="@+id/btnPlay"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_media_play"
            android:contentDescription="재생"
            android:background="?selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>
    </FrameLayout>

</LinearLayout>
